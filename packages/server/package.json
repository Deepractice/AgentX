{
  "name": "@agentxjs/server",
  "version": "2.0.2",
  "description": "AgentX Server - WebSocket server with Platform support",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agentx-server": "./bin/server.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "bin"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "bun run bin/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "echo 'No tests yet'"
  },
  "dependencies": {
    "@agentxjs/core": "workspace:*",
    "@deepracticex/logger": "^1.2.0"
  },
  "devDependencies": {
    "@agentxjs/node-platform": "workspace:*",
    "@agentxjs/mono-driver": "workspace:*",
    "typescript": "^5.3.3"
  }
}
