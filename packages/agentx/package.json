{
  "name": "agentxjs",
  "version": "2.9.0",
  "description": "AgentX Client SDK - Local and remote AI agent management",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./protocol": {
      "types": "./src/protocol.ts",
      "import": "./src/protocol.ts",
      "default": "./src/protocol.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "bun test bdd/"
  },
  "dependencies": {
    "@agentxjs/core": "workspace:*",
    "@deepracticex/id": "^0.2.0",
    "@deepracticex/logger": "^1.2.0",
    "@deepracticex/rpc": "^1.0.0"
  },
  "devDependencies": {
    "@agentxjs/devtools": "workspace:*",
    "@deepracticex/bdd": "^0.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.3.3"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./protocol": {
        "types": "./dist/protocol.d.ts",
        "import": "./dist/protocol.js",
        "default": "./dist/protocol.js"
      }
    }
  }
}
