{
  "name": "@agentxjs/devtools",
  "version": "2.3.0",
  "description": "Development tools for AgentX - MockDriver, RecordingDriver, Fixtures",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "bdd": "./dist/bdd/cli.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./mock": {
      "types": "./src/mock/index.ts",
      "import": "./src/mock/index.ts",
      "default": "./src/mock/index.ts"
    },
    "./recorder": {
      "types": "./src/recorder/index.ts",
      "import": "./src/recorder/index.ts",
      "default": "./src/recorder/index.ts"
    },
    "./fixtures": {
      "types": "./src/fixtures/index.ts",
      "import": "./src/fixtures/index.ts",
      "default": "./src/fixtures/index.ts"
    },
    "./bdd": {
      "types": "./src/bdd/index.ts",
      "import": "./src/bdd/index.ts",
      "default": "./src/bdd/index.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "fixtures"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "echo 'No tests yet'",
    "bdd": "bdd"
  },
  "dependencies": {
    "@agentxjs/core": "workspace:*",
    "@deepracticex/logger": "^1.2.0"
  },
  "devDependencies": {
    "@agentxjs/claude-driver": "workspace:*",
    "@agentxjs/mono-driver": "workspace:*",
    "@agentxjs/node-platform": "workspace:*",
    "@playwright/test": "^1.50.0",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "agentxjs": ">=2.0.0",
    "@agentxjs/claude-driver": ">=2.0.0",
    "@playwright/test": "^1.50.0",
    "@cucumber/cucumber": "^11.0.0"
  },
  "peerDependenciesMeta": {
    "agentxjs": {
      "optional": true
    },
    "@agentxjs/claude-driver": {
      "optional": true
    },
    "@playwright/test": {
      "optional": true
    },
    "@cucumber/cucumber": {
      "optional": true
    }
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./mock": {
        "types": "./dist/mock/index.d.ts",
        "import": "./dist/mock/index.js",
        "default": "./dist/mock/index.js"
      },
      "./recorder": {
        "types": "./dist/recorder/index.d.ts",
        "import": "./dist/recorder/index.js",
        "default": "./dist/recorder/index.js"
      },
      "./fixtures": {
        "types": "./dist/fixtures/index.d.ts",
        "import": "./dist/fixtures/index.js",
        "default": "./dist/fixtures/index.js"
      },
      "./bdd": {
        "types": "./dist/bdd/index.d.ts",
        "import": "./dist/bdd/index.js",
        "default": "./dist/bdd/index.js"
      }
    }
  }
}
