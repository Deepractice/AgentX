{
  "name": "@agentxjs/node-platform",
  "version": "2.9.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./persistence": {
      "types": "./src/persistence/index.ts",
      "import": "./src/persistence/index.ts",
      "default": "./src/persistence/index.ts"
    },
    "./mq": {
      "types": "./src/mq/index.ts",
      "import": "./src/mq/index.ts",
      "default": "./src/mq/index.ts"
    },
    "./network": {
      "types": "./src/network/index.ts",
      "import": "./src/network/index.ts",
      "default": "./src/network/index.ts"
    },
    "./workspace": {
      "types": "./src/workspace/index.ts",
      "import": "./src/workspace/index.ts",
      "default": "./src/workspace/index.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "echo 'No tests yet'"
  },
  "dependencies": {
    "@agentxjs/core": "workspace:*",
    "@deepracticex/logger": "^1.2.0",
    "execa": "9.6.1",
    "rxjs": "^7.8.2",
    "unstorage": "^1.10.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.10",
    "typescript": "^5.3.3"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./persistence": {
        "types": "./dist/persistence/index.d.ts",
        "import": "./dist/persistence/index.js",
        "default": "./dist/persistence/index.js"
      },
      "./mq": {
        "types": "./dist/mq/index.d.ts",
        "import": "./dist/mq/index.js",
        "default": "./dist/mq/index.js"
      },
      "./network": {
        "types": "./dist/network/index.d.ts",
        "import": "./dist/network/index.js",
        "default": "./dist/network/index.js"
      },
      "./workspace": {
        "types": "./dist/workspace/index.d.ts",
        "import": "./dist/workspace/index.js",
        "default": "./dist/workspace/index.js"
      }
    }
  }
}
